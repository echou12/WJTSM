// prisma/schema.prisma
// DATABASE: Neon PostgreSQL (serverless)
// FUTURE EXTENSION: Switch provider to "mysql" or "sqlite" for other databases

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // For Neon serverless with connection pooling:
  directUrl = env("DIRECT_URL")
}

// ─── AUTH ────────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── USERS (Consultants / Staff / Admins) ────────────────────────────────────

enum UserRole {
  superadmin
  admin
  manager
  consultant
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String
  role          UserRole  @default(consultant)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  // Consultant-specific relations
  players   Player[]   @relation("ConsultantPlayers")
  groups    Group[]    @relation("ConsultantGroups")
}

// ─── GROUPS ──────────────────────────────────────────────────────────────────

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  consultantId String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  consultant User?    @relation("ConsultantGroups", fields: [consultantId], references: [id])
  players    Player[]
}

// ─── PLAYERS ─────────────────────────────────────────────────────────────────

enum PlayerStatus {
  active
  inactive
  blacklisted
  vip
}

model Player {
  id             String       @id @default(cuid())
  // FUTURE EXTENSION: Link to Smartico player ID for API sync
  smarticoId     String?      @unique
  name           String
  phone          String?
  email          String?
  status         PlayerStatus @default(active)
  vipLevel       Int          @default(0)
  groupId        String?
  consultantId   String?
  isBlacklisted  Boolean      @default(false)
  blacklistNote  String?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  group       Group?      @relation(fields: [groupId], references: [id])
  consultant  User?       @relation("ConsultantPlayers", fields: [consultantId], references: [id])
  transfers   Transfer[]
  contacts    ContactLog[]
}

// ─── TRANSFERS (Deposits / Withdrawals) ──────────────────────────────────────

enum TransferType {
  deposit
  withdrawal
}

model Transfer {
  id         String       @id @default(cuid())
  playerId   String
  type       TransferType
  amount     Float
  currency   String       @default("BRL")
  // Platform profit (house edge)
  houseProfit Float?
  note       String?
  transferAt DateTime     @default(now())
  createdAt  DateTime     @default(now())

  player Player @relation(fields: [playerId], references: [id])
}

// ─── CONTACT LOG ─────────────────────────────────────────────────────────────

model ContactLog {
  id        String   @id @default(cuid())
  playerId  String
  note      String
  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id])
}

